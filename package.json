{
  "name": "mathplus",
  "version": "1.0.0",
  "description": "MathPlus Desktop App",
  "main": "main.js",
  "author": "Fabian Luna",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.mathplus.app",
    "productName": "MathPlus",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/logo.ico"
    },
    "files": [
      "main.js",
      "package.json",
      "frontend/dist/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/dist/mathplus-backend.exe",
        "to": "mathplus-backend.exe",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fabian-Luna-Vicente/MathPlus.git"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.33.0",
    "katex": "^0.16.28",
    "lucide-react": "^0.563.0",
    "react-katex": "^3.1.0",
    "tailwind-merge": "^3.4.0"
  }
}